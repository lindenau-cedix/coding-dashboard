# =============================================================================
# Coding Dashboard - Environment (systemd EnvironmentFile)
# Zielpfad: /etc/coding-dashboard/coding-dashboard.env  (chmod 640, root:<user>)
# Der Installer generiert diese Datei; hier zur Referenz.
# =============================================================================

# --- Security ---
# Langes Zufallssecret, z.B.: openssl rand -hex 32
CD_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
CD_ADMIN_USERNAME=admin
# Auth (Login + Bearer-Token) ist standardmaessig AUS, solange kein Passwort-Hash
# gesetzt ist -- gedacht fuer Deployments hinter einem authentifizierenden Proxy
# (z.B. Cloudflare Tunnel / Access). Dann erscheint kein Login-Screen.
# Soll ein Login erzwungen werden: pbkdf2-Hash via `python -m app.cli hash-password`
# eintragen (aktiviert die Auth automatisch).
CD_ADMIN_PASSWORD_HASH=
# Optionaler Override: true erzwingt die Auth (auch ohne Hash -> Login unmoeglich,
# bis ein Hash gesetzt ist), false deaktiviert sie selbst bei gesetztem Hash.
# Leer = automatisch (an, sobald CD_ADMIN_PASSWORD_HASH gesetzt ist).
CD_REQUIRE_AUTH=

# --- GitHub ---
# Personal Access Token mit 'repo'-Scope (fein-granular: Contents+Administration
# read/write für die Ziel-Repos). Für "Repo löschen" zusätzlich delete_repo.
CD_GITHUB_TOKEN=
# Optional: Org/User, unter dem neue Repos angelegt werden. Leer = authentifizierter User.
CD_GITHUB_OWNER=

# --- Storage ---
CD_DATA_DIR=/var/lib/coding-dashboard

# --- Git-Identität für automatische Commits ---
CD_GIT_AUTHOR_NAME=Coding Dashboard
CD_GIT_AUTHOR_EMAIL=coding-dashboard@localhost
CD_DEFAULT_BRANCH=main

# --- Dateien / Auslieferung ---
CD_AGENTS_CONFIG_PATH=/etc/coding-dashboard/config.yaml
CD_FRONTEND_DIST=/opt/coding-dashboard/frontend/dist

# --- CORS (Android-App / andere Origins). "*" spiegelt die konkrete Origin,
#     damit Cloudflare-Access-Cookies mit credentials:include funktionieren.
#     Strenger: CD_CORS_ORIGINS=https://localhost,https://dash.example.com
# ---
CD_CORS_ORIGINS=*

# --- Bind (nginx proxied hierauf) ---
CD_HOST=127.0.0.1
CD_PORT=8000

# --- Heartbeat (auto-poll GitHub issues + auto-spawn Claude Code) ---
# Hauptschalter. Leer = aus; das Dashboard fuehrt dann KEINE automatischen
# Tick-Loops aus. Die UI auf /heartbeat kann den Schalter zusaetzlich im
# laufenden Prozess umlegen, das gilt aber nur bis zum Neustart.
CD_HEARTBEAT_ENABLED=false
# Wie oft der Heartbeat aufwacht und nach neuen offenen Issues schaut.
# Mindestens 5 Minuten, um freundlich zu GitHubs Rate Limits zu bleiben.
CD_HEARTBEAT_INTERVAL_SECONDS=900
# Maximal gleichzeitig laufende Projekt-Polls pro Tick.
CD_HEARTBEAT_MAX_CONCURRENT=2
# Nach einem erfolgreichen Heartbeat-Task pro Projekt so viele Minuten
# warten, bevor ein neuer gestartet wird. Failed/Error/Cancelled Tasks
# zaehlen NICHT in den Cooldown.
CD_HEARTBEAT_COOLDOWN_MINUTES=30
# Welcher Agent fuer automatische Fix-Tasks genutzt wird. Default "claude"
# (Claude Code). Andere Agent-Keys aus config.yaml sind ebenfalls moeglich
# (z.B. "codex").
CD_HEARTBEAT_AGENT_KEY=claude
# Beim ersten Poll fuer ein Projekt: wie viele Stunden zurueckschauen.
# Spaeter wird stattdessen last_issue_poll_at als ``since``-Wert benutzt.
CD_HEARTBEAT_LOOKBACK_HOURS=24
# Optionale Label-Filter (kommasepariert). Leer = alle offenen Issues.
# Beispiel: "bug,good first issue" -> nur Issues mit mindestens einem
# dieser Labels werden an Agenten weitergegeben.
CD_HEARTBEAT_LABELS=
# Opt-in Filter: Herzschlag soll nur Issues fixen, die einer bestimmten
# Person (oder einem Team-Account) auf GitHub zugewiesen sind.
# Komma-separierte Liste von GitHub-Logins (z. B. "alice,bot-account").
# Leer = automatisch aus dem Token-Login aufgeloest (ein einzelner Login).
# Wenn weder ENV noch /user einen Login liefern, tickt der Heartbeat NICHT
# (fail-closed: lieber gar nichts auto-fixen als Issues, die der Operator
# gar nicht angefordert hat).
CD_HEARTBEAT_ASSIGNEE_LOGINS=
# Soll das Dashboard nach einem erfolgreichen Heartbeat-Fix einen
# Kommentar mit Commit-Nr. + Branch-URL auf das GitHub-Issue posten?
# Default: true. Funktioniert nur, wenn CD_GITHUB_TOKEN gesetzt ist und
# das Issue einen Token hat, der auf das Repo schreiben darf.
CD_HEARTBEAT_COMMENT_ON_SUCCESS=true
# Soll das Dashboard das Issue automatisch schliessen, wenn der Fix
# sauber auf dem Default-Branch gelandet ist (merge_state=merged +
# pushed=true)? Default: true. Bei Merge-Konflikt bleibt das Issue offen.
CD_HEARTBEAT_CLOSE_ON_MERGE=true

# --- Env profiles (operator-level: per-task / heartbeat ANTHROPIC_* injection) ---
# Lege Profile unter /settings/env-profiles an (Token wird mit CD_SECRET_KEY
# verschluesselt). Setze hier einen Standard-Schluessel, den der Heartbeat fuer
# ALLE auto-gestarteten Tasks benutzt, sofern das Projekt keinen Override hat.
# Leer = Standard (Anthropic).
CD_HEARTBEAT_ENV_PROFILE_KEY=

# --- Claude on host over SSH (per-task "Runner: host") ---
# Standard: leer = Claude laeuft nur im Container. Setze CD_CLAUDE_SSH_USER
# (und optional CD_CLAUDE_SSH_HOST/_PORT), damit das Dashboard einen zusaetzlichen
# AgentSpec "claude-host" anlegt, der das host-seitige `claude` ueber SSH treibt
# (analog zum bestehenden Hermes-SSH-Muster). Dann steht im Start-Formular der
# "Runner: host"-Toggle pro Task zur Verfuegung.
# CD_CLAUDE_SSH_USER=
# CD_CLAUDE_SSH_HOST=host.docker.internal
# CD_CLAUDE_SSH_PORT=22
