# =============================================================================
# Coding Dashboard — Docker secrets / settings
#
# Copy this file to  deploy/docker/coding-dashboard.docker.env  and fill it in.
# The real file holds SECRETS and is git-ignored. docker-compose.yml loads it
# via `env_file`, so the values become environment variables in the container.
#
# Generate the two crypto values once (the image must be built first):
#   CD_SECRET_KEY:          openssl rand -hex 32
#   CD_ADMIN_PASSWORD_HASH: docker compose run --rm dashboard python -m app.cli hash-password 'your-password'
# =============================================================================

# --- Login (single user) ---
CD_SECRET_KEY=
CD_ADMIN_USERNAME=admin
CD_ADMIN_PASSWORD_HASH=

# --- GitHub ---
# PAT with 'repo' scope (fine-grained: Contents + Administration read/write for
# the target repos; add delete_repo / Administration:write to delete repos).
CD_GITHUB_TOKEN=
# Org/user new repos are created under. Empty => the authenticated user.
CD_GITHUB_OWNER=

# --- Git identity for the automatic commits ---
CD_GIT_AUTHOR_NAME=Coding Dashboard
CD_GIT_AUTHOR_EMAIL=coding-dashboard@localhost
CD_DEFAULT_BRANCH=main

# --- CORS (Android app / other origins) ---
# "*" reflects the concrete Origin so credentialed CORS works with the
# Capacitor https://localhost WebView origin. Stricter:
#   CD_CORS_ORIGINS=https://localhost,https://dash.example.com
CD_CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# NOTE: agent (Anthropic/OpenAI/Hermes) credentials are intentionally NOT here.
# Claude + Codex log in interactively and persist in the cd-home volume:
#       docker compose exec dashboard claude        # log in inside the TUI
#       docker compose exec dashboard codex login
# Hermes is DIFFERENT: it runs the HOST's Hermes install (the host's ~/.hermes
# and uv Python are bind-mounted into the container — see docker-compose.yml), so
# its login/config/memory are shared with the host. No login needed here; log in
# on the host with `hermes` if it isn't already.
#
# Build the image matched to the DEST host — these are SHELL vars consumed by
# docker-compose.yml interpolation (NOT this env_file):
#   HERMES_HOST_HOME   home dir of the user that owns ~/.hermes (the path baked
#                      into the host venv launcher); default /home/debian.
#   APP_UID / APP_GID  set to that user's uid/gid so files Hermes writes into the
#                      shared ~/.hermes stay host-owned; keep stable across builds
#                      (a change orphans the chowned cd-home volume).
#   CD_HERMES_HOST_DIR / CD_HERMES_UV_DIR  override the host source paths
#                      (defaults ~/.hermes and ~/.local/share/uv).
#     APP_UID=$(stat -c %u ~/.hermes) APP_GID=$(stat -c %g ~/.hermes) \
#       HERMES_HOST_HOME=$HOME docker compose build
# -----------------------------------------------------------------------------
