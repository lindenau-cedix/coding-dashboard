# =============================================================================
# Coding Dashboard — Docker secrets / settings
#
# Copy this file to  deploy/docker/coding-dashboard.docker.env  and fill it in.
# The real file holds SECRETS and is git-ignored. docker-compose.yml loads it
# via `env_file`, so the values become environment variables in the container.
#
# Generate the secret once:
#   CD_SECRET_KEY:          openssl rand -hex 32
# Auth is OFF by default (no login screen) — intended for a setup behind an
# authenticating proxy such as a Cloudflare tunnel/Access. To require a login,
# also generate a password hash (the image must be built first) and set it below:
#   CD_ADMIN_PASSWORD_HASH: docker compose run --rm dashboard python -m app.cli hash-password 'your-password'
# =============================================================================

# --- Login (single user) ---
CD_SECRET_KEY=
CD_ADMIN_USERNAME=admin
# Leave empty to run WITHOUT auth (Cloudflare tunnel in front). Set a pbkdf2 hash
# to require a login (this auto-enables auth).
CD_ADMIN_PASSWORD_HASH=
# Optional override: true forces auth on, false forces it off even with a hash.
# Empty = auto (on iff CD_ADMIN_PASSWORD_HASH is set).
CD_REQUIRE_AUTH=

# --- GitHub ---
# PAT with 'repo' scope (fine-grained: Contents + Administration read/write for
# the target repos; add delete_repo / Administration:write to delete repos).
CD_GITHUB_TOKEN=
# Org/user new repos are created under. Empty => the authenticated user.
CD_GITHUB_OWNER=

# --- Git identity for the automatic commits ---
CD_GIT_AUTHOR_NAME=Coding Dashboard
CD_GIT_AUTHOR_EMAIL=coding-dashboard@localhost
CD_DEFAULT_BRANCH=main

# --- CORS (Android app / other origins) ---
# "*" reflects the concrete Origin so credentialed CORS works with the
# Capacitor https://localhost WebView origin. Stricter:
#   CD_CORS_ORIGINS=https://localhost,https://dash.example.com
CD_CORS_ORIGINS=*

# --- Heartbeat (auto-poll GitHub issues + auto-spawn Claude Code) ---
# Master switch. Off by default in Docker; enable via the /heartbeat UI
# inside the running container (in-memory, until the next restart) or
# set CD_HEARTBEAT_ENABLED=true here for persistence.
CD_HEARTBEAT_ENABLED=false
CD_HEARTBEAT_INTERVAL_SECONDS=900
CD_HEARTBEAT_MAX_CONCURRENT=2
CD_HEARTBEAT_COOLDOWN_MINUTES=30
CD_HEARTBEAT_AGENT_KEY=claude
CD_HEARTBEAT_LOOKBACK_HOURS=24
# Optional comma-separated label filter. Empty = all open issues.
CD_HEARTBEAT_LABELS=
# Opt-in assignee filter: only auto-fix issues assigned to one of these
# GitHub logins (comma-separated). Empty = auto-resolve from the
# CD_GITHUB_TOKEN's own login (a single implicit login). Fail-closed: if
# neither the env var nor the /user lookup resolves a login, the heartbeat
# tick is skipped entirely so we never silently auto-fix unclaimed issues.
CD_HEARTBEAT_ASSIGNEE_LOGINS=
# Should the dashboard post a comment with the commit hash + branch URL
# on the GitHub issue after a heartbeat-spawned task lands a commit?
# Default: true. Requires CD_GITHUB_TOKEN with write access to the repo.
CD_HEARTBEAT_COMMENT_ON_SUCCESS=true
# Should the dashboard close the issue automatically when the heartbeat
# fix lands cleanly on the default branch (merge_state=merged + pushed)?
# Default: true. Conflict branches leave the issue open.
CD_HEARTBEAT_CLOSE_ON_MERGE=true

# Default env-profile (key from /settings/env-profiles) used by the heartbeat
# when auto-spawning a Claude Code task. Per-project override on the /heartbeat
# page beats this. Empty = today's behaviour, no env injection (standard
# Anthropic auth / endpoint). Token is stored encrypted with CD_SECRET_KEY.
CD_HEARTBEAT_ENV_PROFILE_KEY=

# --- Host-over-SSH wiring (shared by Hermes AND Claude Code) ---------------
# Claude Code always runs on the host over SSH when CD_CLAUDE_SSH_USER is
# set (the `claude` binary is never installed in the image — there's no
# Anthropic login baked into the container). Hermes IS installed into the
# image by default (the Dockerfile's HERMES_INSTALL_CMD is the upstream
# one-liner), so the dashboard can run `hermes` directly inside the
# container.
#
# Override Hermes to also run on the host over SSH (the previous default)
# when you want exactly one Hermes process tree on the host — for paired
# channels (WhatsApp, Telegram) and cronjobs that should keep firing when
# the dashboard container is down. In that mode set CD_HERMES_SSH_USER and
# also set HERMES_INSTALL_CMD= at build time so the image doesn't install
# a second Hermes. The dashboard's per-task "Runner: host" dropdown then
# shows a second Hermes option that runs the host's Hermes over SSH; the
# container-side Hermes stays selectable for tasks where you specifically
# want a clean in-container environment.
#
# Configure ONE pair of CD_{HERMES,CLAUDE}_SSH_{USER,HOST,PORT} env vars
# and it applies to BOTH the hermes-host and claude-host siblings — the
# unset env's values fall back to the set one (defaulting
# host="host.docker.internal" and port=22). Configure BOTH only when
# Hermes and Claude truly run on different hosts. Configure NEITHER to
# disable both -host siblings entirely (no SSH route; the per-task
# "Runner: host" dropdown is hidden for both agents).
#
# Host prerequisites (only relevant when at least one of the two CD_*_SSH_USER
# vars is set): sshd running; the chosen agent CLI(s) installed + logged in
# for that user; the container's public key in that user's
# ~/.ssh/authorized_keys; and the shared staging dir (CD_HERMES_STAGING_HOST_DIR)
# owned by this user. See deploy/docker/entrypoint.sh for which key file
# the entrypoint expects for each agent (id_hermes / id_claude).

# --- Hermes runs on the HOST over SSH (optional override) ---
# Leave CD_HERMES_SSH_USER EMPTY to use the in-image Hermes (the dashboard
# runs `hermes` directly inside the container). Set it to run the host's
# Hermes over SSH instead — e.g. when you want exactly one Hermes process
# tree on the host for WhatsApp/Telegram/cronjobs. Setting this var also
# lights up the `claude-host` sibling (see "Host-over-SSH wiring" above).
CD_HERMES_SSH_USER=
CD_HERMES_SSH_HOST=host.docker.internal
CD_HERMES_SSH_PORT=22
# Optional: pin the private-key path the container uses for the Hermes SSH
# connection. Default /home/app/.ssh/id_hermes. If unset AND that file does
# not exist on disk, the dashboard falls back to the other agent's key
# (id_claude) so a Hermes-only deploy that ships one shared key still
# works for both siblings. See deploy/docker/entrypoint.sh + backend/app/
# config_bootstrap.py for the exact resolution order.
CD_HERMES_SSH_KEY=

# --- Claude Code runs on the HOST over SSH (mirrors Hermes-SSH) ---
# See "Host-over-SSH wiring" block above — these vars also drive the
# `hermes-host` sibling when CD_HERMES_SSH_USER is unset.
CD_CLAUDE_SSH_USER=
CD_CLAUDE_SSH_HOST=host.docker.internal
CD_CLAUDE_SSH_PORT=22
# Optional: pin the private-key path for Claude's SSH connection.
# Default /home/app/.ssh/id_claude; falls back to id_hermes when that
# file is missing. Pin via CD_CLAUDE_SSH_KEY to override the fallback.
CD_CLAUDE_SSH_KEY=

# -----------------------------------------------------------------------------
# The following are SHELL vars consumed by docker-compose.yml interpolation at
# build/up time (NOT this env_file):
#   APP_UID / APP_GID        uid/gid of the host user that runs Hermes and owns
#                            the shared staging dir, so file ownership in the staged
#                            copy matches. Keep stable across rebuilds (a change
#                            orphans the chowned cd-home volume). e.g. APP_UID=$(id -u)
#   CD_HERMES_STAGING_HOST_DIR  host path bind-mounted (at the SAME path) where the
#                            dashboard stages a COPY of the project for the host's
#                            Hermes to edit; merged back + pushed after each run.
#                            Default /tmp/coding-dashboard-hermes. Must exist + be
#                            owned by APP_UID:APP_GID. The dashboard's own data
#                            (DB + repos) stays in the private cd-data volume.
#   CD_HERMES_SSH_KEY_HOST   host path of the PRIVATE key the container uses to ssh
#                            in. Default ~/.ssh/id_coding_dashboard; mounted
#                            read-only at /home/app/.ssh/id_hermes.
#   CD_HOST_LOCK_HOST_DIR    host path bind-mounted (at the SAME path) where the
#                            dashboard drops one lock file per active task/goal/
#                            session ("<kind>-<id>.lock") so operators can see on
#                            the host whether something is running. Defaults to
#                            /var/lock/coding-dashboard. Outside that scope, the
#                            container cannot reach the host; the dashboard also
#                            writes here its own session pids for forensics.
#                            Best-effort visibility only — failures to write
#                            never abort a run.
#   CD_CODEX_SANDBOX         Codex sandbox mode inside Docker. Default from
#                            docker-compose.yml is danger-full-access because
#                            workspace-write needs bubblewrap/unprivileged user
#                            namespaces, often disabled inside containers. Set
#                            CD_CODEX_SANDBOX=workspace-write only if your host
#                            allows it.
# Example one-time host setup + build:
#   mkdir -p /tmp/coding-dashboard-hermes /var/lock/coding-dashboard
#   # /var/lock/coding-dashboard may already exist (the /var/lock dir is shipped
#   # with the OS) — just make sure the app user (APP_UID below) can write into it.
#   chown "$(id -u)":"$(id -g)" /var/lock/coding-dashboard
#   ssh-keygen -t ed25519 -N '' -f ~/.ssh/id_coding_dashboard
#   cat ~/.ssh/id_coding_dashboard.pub >> ~/.ssh/authorized_keys
#   APP_UID=$(id -u) APP_GID=$(id -g) docker compose build
# -----------------------------------------------------------------------------
