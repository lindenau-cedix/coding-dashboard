# =============================================================================
# Coding Dashboard — Docker secrets / settings
#
# Copy this file to  deploy/docker/coding-dashboard.docker.env  and fill it in.
# The real file holds SECRETS and is git-ignored. docker-compose.yml loads it
# via `env_file`, so the values become environment variables in the container.
#
# Generate the secret once:
#   CD_SECRET_KEY:          openssl rand -hex 32
# Auth is OFF by default (no login screen) — intended for a setup behind an
# authenticating proxy such as a Cloudflare tunnel/Access. To require a login,
# also generate a password hash (the image must be built first) and set it below:
#   CD_ADMIN_PASSWORD_HASH: docker compose run --rm dashboard python -m app.cli hash-password 'your-password'
# =============================================================================

# --- Login (single user) ---
CD_SECRET_KEY=
CD_ADMIN_USERNAME=admin
# Leave empty to run WITHOUT auth (Cloudflare tunnel in front). Set a pbkdf2 hash
# to require a login (this auto-enables auth).
CD_ADMIN_PASSWORD_HASH=
# Optional override: true forces auth on, false forces it off even with a hash.
# Empty = auto (on iff CD_ADMIN_PASSWORD_HASH is set).
CD_REQUIRE_AUTH=

# --- GitHub ---
# PAT with 'repo' scope (fine-grained: Contents + Administration read/write for
# the target repos; add delete_repo / Administration:write to delete repos).
CD_GITHUB_TOKEN=
# Org/user new repos are created under. Empty => the authenticated user.
CD_GITHUB_OWNER=

# --- Git identity for the automatic commits ---
CD_GIT_AUTHOR_NAME=Coding Dashboard
CD_GIT_AUTHOR_EMAIL=coding-dashboard@localhost
CD_DEFAULT_BRANCH=main

# --- CORS (Android app / other origins) ---
# "*" reflects the concrete Origin so credentialed CORS works with the
# Capacitor https://localhost WebView origin. Stricter:
#   CD_CORS_ORIGINS=https://localhost,https://dash.example.com
CD_CORS_ORIGINS=*

# --- Hermes runs on the HOST over SSH ---
# Hermes is NOT run inside the container (that duplicated its cronjobs / WhatsApp
# / Telegram replies). Instead the container `ssh`es into the host and runs the
# host's `hermes` there — one Hermes, on the host. Set the host user to ENABLE
# Hermes; leave empty to disable it (or to use a self-contained in-image Hermes).
# These are read by deploy/docker/entrypoint.sh when it generates config.yaml on
# first boot (delete config.yaml in the cd-config volume to regenerate later).
#   Host prerequisites: sshd running; hermes installed + logged in for this user;
#   the container's public key in that user's ~/.ssh/authorized_keys; and the
#   shared staging dir (CD_HERMES_STAGING_HOST_DIR) owned by this user.
CD_HERMES_SSH_USER=
# Host address reachable from the container. host.docker.internal is mapped to the
# host gateway via extra_hosts in docker-compose.yml; sshd must listen on it.
CD_HERMES_SSH_HOST=host.docker.internal
CD_HERMES_SSH_PORT=22

# -----------------------------------------------------------------------------
# The following are SHELL vars consumed by docker-compose.yml interpolation at
# build/up time (NOT this env_file):
#   APP_UID / APP_GID        uid/gid of the host user that runs Hermes and owns
#                            the shared staging dir, so file ownership in the staged
#                            copy matches. Keep stable across rebuilds (a change
#                            orphans the chowned cd-home volume). e.g. APP_UID=$(id -u)
#   CD_HERMES_STAGING_HOST_DIR  host path bind-mounted (at the SAME path) where the
#                            dashboard stages a COPY of the project for the host's
#                            Hermes to edit; merged back + pushed after each run.
#                            Default /tmp/coding-dashboard-hermes. Must exist + be
#                            owned by APP_UID:APP_GID. The dashboard's own data
#                            (DB + repos) stays in the private cd-data volume.
#   CD_HERMES_SSH_KEY_HOST   host path of the PRIVATE key the container uses to ssh
#                            in. Default ~/.ssh/id_coding_dashboard; mounted
#                            read-only at /home/app/.ssh/id_hermes.
#   CD_HOST_LOCK_HOST_DIR    host path bind-mounted (at the SAME path) where the
#                            dashboard drops one lock file per active task/goal/
#                            session ("<kind>-<id>.lock") so operators can see on
#                            the host whether something is running. Defaults to
#                            /var/lock/coding-dashboard. Outside that scope, the
#                            container cannot reach the host; the dashboard also
#                            writes here its own session pids for forensics.
#                            Best-effort visibility only — failures to write
#                            never abort a run.
#   CD_CODEX_SANDBOX         Codex sandbox mode inside Docker. Default from
#                            docker-compose.yml is danger-full-access because
#                            workspace-write needs bubblewrap/unprivileged user
#                            namespaces, often disabled inside containers. Set
#                            CD_CODEX_SANDBOX=workspace-write only if your host
#                            allows it.
# Example one-time host setup + build:
#   mkdir -p /tmp/coding-dashboard-hermes /var/lock/coding-dashboard
#   # /var/lock/coding-dashboard may already exist (the /var/lock dir is shipped
#   # with the OS) — just make sure the app user (APP_UID below) can write into it.
#   chown "$(id -u)":"$(id -g)" /var/lock/coding-dashboard
#   ssh-keygen -t ed25519 -N '' -f ~/.ssh/id_coding_dashboard
#   cat ~/.ssh/id_coding_dashboard.pub >> ~/.ssh/authorized_keys
#   APP_UID=$(id -u) APP_GID=$(id -g) docker compose build
# -----------------------------------------------------------------------------
